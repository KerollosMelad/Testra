generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  description    String?
  organization   String
  project        String
  token          String
  aiModel        String
  temperature    Float
  maxTokens      Int
  autoGeneration Boolean
  aiChat         Boolean
  codeGeneration Boolean
  createdAt      DateTime @default(now())
  lastSync       DateTime?
  
  // Relations
  testCases      TestCase[]
  testSuites     TestSuite[]
}

model TestCase {
  id                String   @id @default(uuid())
  title             String
  description       String
  type              TestType
  priority          Priority
  status            TestStatus @default(DRAFT)
  steps             Json     // Array of TestStep objects
  expectedResult    String
  preconditions     String?
  testData          Json?    // Additional test data as JSON
  estimatedDuration Int?     // Duration in minutes
  projectId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  generatedAt       DateTime?
  generatedBy       GeneratedBy?
  generatedCode     String?  // Generated automation code
  
  // Relations
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workItemRelations TestCaseWorkItemRelation[]
  parentRelations   TestCaseRelation[] @relation("ParentTestCase")
  childRelations    TestCaseRelation[] @relation("ChildTestCase")
  testSuiteItems    TestSuiteItem[]
  
  @@index([projectId])
  @@index([type])
  @@index([status])
}

model TestCaseWorkItemRelation {
  id           String       @id @default(uuid())
  testCaseId   String
  workItemId   String       // Azure DevOps work item ID
  relationType RelationType
  createdAt    DateTime     @default(now())
  
  // Relations
  testCase     TestCase     @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  
  @@unique([testCaseId, workItemId, relationType])
  @@index([workItemId])
}

model TestSuite {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        SuiteType
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases   TestSuiteItem[]
  
  @@index([projectId])
}

model TestSuiteItem {
  id          String    @id @default(uuid())
  testSuiteId String
  testCaseId  String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  
  // Relations
  testSuite   TestSuite @relation(fields: [testSuiteId], references: [id], onDelete: Cascade)
  testCase    TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  
  @@unique([testSuiteId, testCaseId])
  @@index([testSuiteId])
}

model TestCaseRelation {
  id                String              @id @default(uuid())
  parentTestCaseId  String
  childTestCaseId   String
  relationType      TestCaseRelationType
  createdAt         DateTime            @default(now())
  
  // Relations
  parentTestCase    TestCase            @relation("ParentTestCase", fields: [parentTestCaseId], references: [id], onDelete: Cascade)
  childTestCase     TestCase            @relation("ChildTestCase", fields: [childTestCaseId], references: [id], onDelete: Cascade)
  
  @@unique([parentTestCaseId, childTestCaseId, relationType])
}

// Enums
enum TestType {
  UNIT
  INTEGRATION
  E2E
  API
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TestStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum GeneratedBy {
  AI
  MANUAL
}

enum RelationType {
  COVERS
  VALIDATES
  DEPENDS_ON
}

enum SuiteType {
  SMOKE
  REGRESSION
  INTEGRATION
  CUSTOM
}

enum TestCaseRelationType {
  PREREQUISITE
  FOLLOWS
  BLOCKS
} 